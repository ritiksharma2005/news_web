# Copy this to .env.local for local development.
# On Vercel, add these as Environment Variables in your project settings instead.

# At least one of these two AI keys is required (Gemini tried first, Groq as fallback)
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Simple shared password so random visitors can't use your AI budget.
# Leave blank to disable the password check entirely.
SITE_PASSWORD=choose_a_password_here
